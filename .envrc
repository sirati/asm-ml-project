# Detect if we have a Pascal GPU (compute capability 6.x)
# Priority:
# 1) Prefer an installed `nvidia-smi` in PATH.
# 2) If not present, but NVIDIA driver is loaded or we're inside a container,
#    try to run `nvidia-smi` provided by a transient nix shell.
# 3) Otherwise fall back to the default flake.
#
# Non-root checks only (no privileged operations).
if command -v nvidia-smi >/dev/null 2>&1; then
  if nvidia-smi --query-gpu=compute_cap --format=csv,noheader 2>/dev/null | grep -q "^6\."; then
    use flake .#pascal
  else
    use flake .#default
  fi
else
  # Check whether NVIDIA kernel module appears loaded or we're in a container.
  # /proc/modules is readable by unprivileged users. Containers are commonly
  # indicated by /.dockerenv or /run/.containerenv.
  if (grep -q '^nvidia' /proc/modules 2>/dev/null) || [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
    if command -v nix >/dev/null 2>&1; then
      # Try to run nvidia-smi via nix shell (non-interactive). If it reports
      # Pascal (6.x) choose the pascal flake, otherwise default.
      if NIXPKGS_ALLOW_UNFREE=1 nix shell --impure nixpkgs#linuxPackages.nvidia_x11 -c 'nvidia-smi --query-gpu=compute_cap --format=csv,noheader' 2>/dev/null | grep -q "^6\."; then
        use flake .#pascal
      else
        use flake .#default
      fi
    else
      # nix not available to provide nvidia-smi; fall back
      use flake .#default
    fi
  else
    use flake .#default
  fi
fi
